    },
    {
      "source": "/tasks/:path*",
      "destination": "https://taskflow-production-47d4.up.railway.app/tasks/:path*"
    },
    {
      "source": "/categories/:path*",
      "destination": "https://taskflow-production-47d4.up.railway.app/categories/:path*"
    },
    {
